# ── 등기조회(postal-tracker) 환경변수 ─────────────────────────────
# Vercel: Project Settings → Environment Variables 에 아래를 등록한다.
# 로컬 개발: 이 파일을 .env.local 로 복사해 값을 채운다.

# [조회에 필수] 공공데이터포털 '국내우편물 종적 조회 서비스' 인증키.
#   ※ Vercel/서버에는 "일반 인증키(Decoding)" 를 넣는다. (코드가 자동 인코딩)
#   미설정 시 실제 조회 대신 데모(목업) 데이터로 화면이 동작한다.
POSTAL_API_KEY=

# [OCR에 필수] 접수증 사진에서 등기번호를 읽는 데 사용.
#   미설정 시 사진 인식은 비활성, 붙여넣기/CSV 조회는 정상 동작.
OPENAI_API_KEY=

# [선택] 방문자 카운터용 Upstash Redis. 없으면 무료 카운터로 자동 대체.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# [선택] 커스텀 도메인 주소 (예: https://내도메인.kr). 붙이면 sitemap/OG에 반영.
NEXT_PUBLIC_SITE_URL=

# [선택] 검색엔진 사이트 소유확인 토큰 (meta 태그로 출력됨)
#   구글 서치콘솔 'HTML 태그' 방식의 content 값
GOOGLE_SITE_VERIFICATION=
#   네이버 서치어드바이저 사이트 등록 시 주는 content 값
NAVER_SITE_VERIFICATION=

# [선택] 개발용: 조회 응답 원본 XML을 응답에 포함하려면 1 (필드 매핑 확인용).
# POSTAL_DEBUG=1
